system requirements DynamicVehicleCompREQv3 for DynamicVehicle::VehicleDynamicv3[
	
/////////////////////////////////////////////VALIDATION///////////////////////////////////////////////////////
  requirement StoppingDistanceAccuracyVal1: "REQ-VDM-VAL-01 The model shall provide a stopping distance prediction with a maximum deviation"[
    description "The stopping distance computation shall remain within a ÝX% error margin when compared to validated reference measurements across all relevant initial speeds. ."
    rationale  "Accurate stopping distance prediction is essential for validating braking performance, safety functions, and ADAS algorithms relying on vehicle dynamics fidelity."
    category Validation.Validity
    val ToleranceMargin = 1
    value predicate #Validation_Property::ToleranceMargin == ToleranceMargin
  ]

  requirement BrakingCapabilityWithCustomInputsVal2: "REQ-VDM-VAL-02 The model shall be able to perform braking actions when custom input signals are provided." [
    description  "The model shall accept external braking commands (e.g., brake pressure, brake torque, deceleration request) and compute the corresponding braking response. It shall support user defined or scenario defined inputs for simulation, testing, and validation purposes."
    rationale  "Supporting custom braking inputs enables integration with control algorithms, scenario based testing, and validation of braking strategies under diverse conditions."
    category Validation.Validity
    val ValidCustomInput = 1
    value predicate #Validation_Property::CustomInputValid == ValidCustomInput
  ]
  
  requirement ValidateReachSpeedScenarioVal3: "REQ-VDM-VAL-03 The model shall validate reach speed scenarios." [
	  description "The model shall reproduce vehicle behavior when accelerating to a specified target speed under normal conditions."
	  rationale "Reach speed scenarios are essential for validating longitudinal dynamics and acceleration performance."
	  category Validation.Validity
	  val ReachSpeed = 1
      value predicate #Validation_Property::ReachSpeedValid == ReachSpeed
	]

  requirement ValidateReachSpeedTurningRightScenarioVal4: "REQ-VDM-VAL-04 The model shall validate reach speed while turning right scenarios." [
	  description "The model shall simulate reaching a target speed while performing right steering inputs."
	  rationale "Combining speed buildup with lateral inputs is necessary to validate coupled longitudinal-lateral dynamics."
	  category Validation.Validity
	  val ReachSpeedTunRight = 1
      value predicate #Validation_Property::ReachSpeedTurnRightValid == ReachSpeedTunRight
	]
	
  requirement ValidateReachSpeedTurningLeftScenarioVal5: "REQ-VDM-VAL-05 The model shall validate reach speed while turning left scenarios." [
	  description "The model shall simulate reaching a target speed while performing left steering inputs."
	  rationale "Combining speed buildup with lateral inputs is necessary to validate coupled longitudinal-lateral dynamics."
	  category Validation.Validity
	  val ReachSpeedTurnLeft = 1
      value predicate #Validation_Property::ReachSpeedTurnLeftValid == ReachSpeedTurnLeft
	]

  requirement ValidateAccelerationScenarioVal6: "REQ-VDM-VAL-06 The model shall validate acceleration scenarios." [
	  description "The model shall simulate acceleration maneuvers across the relevant operating range."
	  rationale "Acceleration behavior is a key indicator of propulsion and torque related model fidelity."
	  category Validation.Validity
	  val Acceleration = 1
      value predicate #Validation_Property::AccelerationValid == Acceleration
	]

  requirement ValidateAEBModerateBrakingScenarioVal7: "REQ-VDM-VAL-07 The model shall validate moderate braking scenarios." [
	  description "The model shall simulate moderate deceleration events triggered by AEB logic."
	  rationale "Moderate braking scenarios are required to validate partial intervention behavior of AEB systems."
	  category Validation.Validity
	  val ModerateBraking = 1
      value predicate #Validation_Property::ModerateBreakingValid == ModerateBraking
	]

  requirement ValidateAEBFullBrakingScenarioVal8: "REQ-VDM-VAL-08 The model shall validate full braking scenarios." [
	  description "The model shall reproduce full force braking events initiated by AEB activation."
	  rationale "Full braking scenarios are essential to evaluate emergency stopping performance."
	  category Validation.Validity
	  val FullBraking = 1
      value predicate #Validation_Property::FullBreakingValid == FullBraking
	]

  requirement ValidateAEBPrefillScenarioVal9: "REQ-VDM-VAL-09 The model shall validate prefill braking scenarios." [
	  description "The model shall simulate prefill activation and its effect on braking response time."
	  rationale "Prefill behavior influences braking latency and is critical for accurate AEB performance modeling."
	  category Validation.Validity
	  val PrefillScenario = 1
      value predicate #Validation_Property::PrefillValid == PrefillScenario
	]
  
  
  ///////////////////////////////////////////////VERIFICATION/////////////////////////////////////
  requirement TechnicalCheckValidationVer1: "REQ-VDM-VER-01 The model shall support validation of the technical check." [
	  description "The model shall reproduce the vehicle behavior required to validate technical inspection criteria such as braking performance, stability, and standardized test responses."
	  rationale "Technical check validation ensures the model can be used to verify compliance with regulatory or internal performance requirements."
  	  category Fidelity.ModelVerification
  	  val TechnicalCheck = 1
      value predicate #Verification_Property::TechnicalChecKCovered == TechnicalCheck
  ]

	requirement VehicleAdaptationVer2: "REQ-VDM-VER-02 The model shall be adapted to the B1318 vehicle." [
	  description "The model shall incorporate the physical, geometric, and dynamic characteristics specific to the B1318 vehicle variant."
	  rationale "Vehicle-specific adaptation ensures that simulation results reflect the actual behavior of the target vehicle."
	  category Fidelity.ModelVerification
	  val Vehicletype = 1
      value predicate #Verification_Property::VehicleType == Vehicletype
	]

	requirement EngineIntegrationVer3: "REQ-VDM-VER-03 The model shall incorporate a ICE engine." [
	  description "The model shall include the torque characteristics, inertia, and dynamic response of the ICE engine."
	  rationale "Accurate motor modeling is required for propulsion, braking, and energy-related simulations."
	  category Fidelity.ModelVerification
	  val Enginetype = 1
      value predicate #Verification_Property::EngineType == Enginetype
	  
	]
	
	requirement PrototypeCorrelationVer4_1: "REQ-VDM-VER-0401 The model shall be correlated with prototype measurements for TT100." [
	  description "The model shall be calibrated and validated using prototype data for the TT100 performance domains."
	  rationale "Correlation ensures that the model accurately reproduces real-world prototype behavior."
	  category Fidelity.ModelVerification
	  val TT100 = 1
      value predicate #Verification_Property::TT100Correlated == TT100
	]
	
	requirement PrototypeCorrelationVer4_2: "REQ-VDM-VER-0402 The model shall be correlated with prototype measurements for TTL." [
	  description "The model shall be calibrated and validated using prototype data for the TTL performance domains."
	  rationale "Correlation ensures that the model accurately reproduces real-world prototype behavior."
	  category Fidelity.ModelVerification
	  val TTL = 1
      value predicate #Verification_Property::TTLCorrelated == TTL
	]
	
	requirement CommunicationFrequencyVer5: "REQ-VDM-VER-05 The model shall communicate at 100 Hz." [
	  description "The model shall update and transmit its state variables, forces, and kinematic outputs at a fixed rate of 100 Hz."
	  rationale "A 100 Hz update rate is required for real-time integration with vehicle controllers and simulation platforms."
	  category Fidelity.ModelVerification
	  val Frq = 100
      value predicate #Verification_Property::Frequency == Frq
	]
	
	requirement TotalMassVer6: "REQ-VDM-VER-06 The model shall use a total mass of 1715 kg." [
	  description "The model shall be parameterized with a total mass of 1715 kg for all dynamic computations."
	  rationale "Correct mass is essential for accurate longitudinal, lateral, and vertical dynamics."
	  category Fidelity.ModelVerification
	  val totalMass = 1715
      value predicate #Verification_Property::VehicleTotalMass == totalMass
	]
	
	requirement FrontMassDistributionVer7: "REQ-VDM-VER-07 The model shall use a front mass distribution of 51%." [
	  description "The model shall allocate 51% of the total mass to the front axle."
	  rationale "Accurate mass distribution is required for realistic braking, steering, and stability behavior."
	  category Fidelity.ModelVerification
	  val FrontMass = 51
      value predicate #Verification_Property::FrontMassDistribution == FrontMass
	]
	
	requirement RearMassDistributionVer8: "REQ-VDM-VER-08 The model shall use a rear mass distribution of 49%." [
	  description "The model shall allocate 49% of the total mass to the rear axle."
	  rationale "Rear mass distribution affects traction, stability, and vertical dynamics."
	  category Fidelity.ModelVerification
	  val RearMass = 49
      value predicate #Verification_Property::RearMassDistribution == RearMass
	]
	
	requirement TireBrandVer9: "REQ-VDM-VER-09 The model shall use Continental tires." [
	  description "The tire model shall be parameterized using Continental tire characteristics."
	  rationale "Tire brand influences friction curves, stiffness, and dynamic response."
	  category Fidelity.ModelVerification
	  val TiresBrand = 1
      value predicate #Verification_Property::TiresBrand == TiresBrand
	]
	
	requirement TireModelVer10: "REQ-VDM-VER-10 The model shall use the Ecocontact7 tire model." [
	  description "The model shall incorporate the Ecocontact7 tire characteristics for force generation."
	  rationale "Tire model fidelity is essential for accurate longitudinal and lateral dynamics."
	  category Fidelity.ModelVerification
	  val Tiresmodel = 1
      value predicate #Verification_Property::TiresModel == Tiresmodel
	]
	
	requirement TireDimensionsWidthVer11: "REQ-VDM-VER-11 The model shall use tire dimensions 195/60 R16." [
	  description "The tire model shall be configured with a width of 195 mm."
	  rationale "Tire dimensions affect stiffness, inertia, and contact patch behavior."
	  category Fidelity.ModelVerification
	  val TiresWidth = 195
      value predicate #Verification_Property::TiresDimensions_width == TiresWidth
	]
	
	requirement TireDimensionsAspectRatioVer11: "REQ-VDM-VER-11 The model shall use tire dimensions 195/60 R16." [
	  description "The tire model shall be configured with an aspect ratio 60."
	  rationale "Tire dimensions affect stiffness, inertia, and contact patch behavior."
	  category Fidelity.ModelVerification
	  val TiresAR = 60
      value predicate #Verification_Property::TiresDimensions_aspectratio == TiresAR
	]
	requirement TireDimensionsRimDiameterVer11: "REQ-VDM-VER-11 The model shall use tire dimensions 195/60 R16." [
	  description "The tire model shall be configured with a 16-inch rim diameter."
	  rationale "Tire dimensions affect stiffness, inertia, and contact patch behavior."
	  category Fidelity.ModelVerification
	  val TiresRimD = 16
      value predicate #Verification_Property::TiresDimensions_rimdiameter == TiresRimD
	]
	
	requirement TirePressureVer12: "REQ-VDM-VER-12 The model shall use a tire pressure of 2.5 bar for all tires." [
	  description "The model shall apply a uniform pressure of 2.5 bar to all tires for stiffness and load distribution calculations."
	  rationale "Tire pressure influences vertical stiffness, grip, and rolling resistance."
	  category Fidelity.ModelVerification
	  val TiresPressure = 2.5
      value predicate #Verification_Property::TiresPressure == TiresPressure
	]
	  
	requirement DavidStandaloneVer13: "REQ-VDM-VER-13 The model shall be a standalone version." [
	  description "The model shall be a standalone version ."
	  rationale "The need requires a standalone model."
	  category Fidelity.ModelVerification
	  val stdalone = 1
      value predicate #Verification_Property::Standalone == stdalone
	]
	  
	requirement CompatibleADASVer14: "REQ-VDM-VER-14 The model shall be a be adapted for ADAS." [
	  description "The model shall be constructed to support ADAS related functionalities and system behaviors."
	  rationale "ADAS functionalities require a model specifically adapted."
	  category Fidelity.ModelVerification
	  val ADAS = 1
      value predicate #Verification_Property::ADAS == ADAS
	]
	////////////////////////////////////////////////MATURITY///////////////////////////////////////////////
	requirement ModelMaturityMat1: "REQ-VDM-MAT-01 The model must be highly mature." [ 
		description "The model shall demonstrate a high level of development maturity, including stable behavior, complete functional implementation, and readiness for operational use." 
		rationale "A highly mature model ensures reliability, stability, and confidence in simulation results."
		category Fidelity.Maturity
		val complexity = 3
    	value predicate #Maturity_Property::Complexity == complexity
	]	
