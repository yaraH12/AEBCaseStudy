system requirements DynamicVehicleREQv3 for DynamicVehicle::VehicleDynamicv3.Impl[
	

  requirement Func1: "REQ-VDM-FUNC-01 The system shall manage brake prefill to reduce braking response time" [
    description  "Prefill management prepares the hydraulic circuit when a potential braking event is detected, improving reaction time." 
    rationale  "Reducing braking latency enhances vehicle safety during emergency maneuvers."
   	category Fidelity.FunctionsCoverage
  ]

  requirement Func2:"REQ-VDM-FUNC-02 The system shall manage motor slip reduction (MSR) to prevent excessive wheel slip during deceleration."  [
    description   "MSR monitors wheel speed and adjusts torque to maintain traction when the vehicle decelerates on low_grip surfaces." 
    rationale   "Preventing wheel slip during deceleration improves stability and control." 
    category Fidelity.FunctionsCoverage
  ]

  requirement Func3: "REQ-VDM-FUNC-03 The system shall manage acceleration slip regulation (ASR) to prevent excessive wheel slip during acceleration." [ 
    description   "ASR monitors wheel traction and reduces torque when slip exceeds defined limits." 
    rationale   "Limiting wheel slip during acceleration improves drivability and stability." 
    category Fidelity.FunctionsCoverage
  ]

  requirement Func4: "REQ-VDM-FUNC-04 The system shall manage vehicle dynamic control to maintain stability during critical maneuvers."  [    
    description   "Vehicle dynamic control adjusts braking and torque distribution to counteract understeer or oversteer." 
    rationale   "Maintaining stability reduces the risk of loss_of_control accidents." 
    category Fidelity.FunctionsCoverage
  ]

  requirement Func5: "REQ-VDM-FUNC-05 The system shall prevent wheel blocking during braking through anti_lock braking management."  [
    description   "The anti_blocking function modulates brake pressure to maintain wheel rotation during heavy braking." 
    rationale   "Preventing wheel lock preserves steering capability and reduces stopping distance." 
    category Fidelity.FunctionsCoverage
  ]

  requirement Func6: "REQ-VDM-FUNC-06 The system shall monitor and manage brake pedal position and activation status." [   
    description   "This includes detecting pedal travel, force, and activation state for braking logic and diagnostics." 
    rationale   "Accurate pedal status is essential for correct braking behavior and safety monitoring." 
    category Fidelity.FunctionsCoverage
  ]

  requirement Func7: "REQ-VDM-FUNC-07 The system shall compute and provide vehicle speed information to dependent functions."   [ 
    description   "Vehicle speed is derived from wheel sensors or other sources and distributed to control modules." 
    rationale   "Accurate speed information is required for braking, stability, and torque control functions." 
    category Fidelity.FunctionsCoverage
  ]

  requirement Func8: "REQ-VDM-FUNC-08 The system shall compute and maintain the vehicle's total mileage."  [   
    description   "Mileage is accumulated from validated speed and distance measurements." 
    rationale   "Odometer information is required for maintenance, diagnostics, and regulatory compliance." 
    category Fidelity.FunctionsCoverage
  ]

  requirement Func9: "REQ-VDM-FUNC-09 The system shall manage assisted parking brake activation and release."  [
    description "This includes automatic engagement under defined conditions and controlled release when driving off." 
    rationale   "Automated parking brake improves safety and user convenience."  
    category Fidelity.FunctionsCoverage
  ]

  requirement Func10: "REQ-VDM-FUNC-10 The system shall acquire and provide steering wheel angle information."  [
    description   "Steering angle is measured and distributed to dynamic control and torque management functions." 
    rationale   "Steering angle is essential for stability control and trajectory estimation." 
    category Fidelity.FunctionsCoverage
  ]

  requirement Func11: "REQ-VDM-FUNC-11 The system shall elaborate the driver's setpoint based on pedal inputs and driving mode."  [
    description   "Driver intent is interpreted from accelerator, brake, and mode selections to generate control targets." 
    rationale   "Correct interpretation of driver intent ensures predictable and safe vehicle behavior."
    category Fidelity.FunctionsCoverage 
  ]

  requirement Func12: "REQ-VDM-FUNC-12 The system shall compute wheel torque setpoints based on driver intent and vehicle conditions."  [
    description   "Torque setpoints consider traction, stability, and powertrain constraints." 
    rationale   "Accurate torque setpoints ensure smooth and safe propulsion." 
    category Fidelity.FunctionsCoverage
  ]

  requirement Func13: "REQ-VDM-FUNC-13 The system shall consolidate shift lever requests and provide a validated gear selection command."  [
    description   "Shift requests are checked for plausibility and translated into actionable commands." 
    rationale   "Correct gear selection is essential for drivability and safety."
    category Fidelity.FunctionsCoverage 
  ]

  requirement Func14:  "REQ-VDM-FUNC-14 The system shall limit wheel torque setpoints based on safety, traction, and system constraints."  [  
    description   "Torque limitations ensure that commanded torque remains within safe and feasible bounds." 
    rationale   "Limiting torque prevents loss of traction, component overload, and unsafe behavior." 
    category Fidelity.FunctionsCoverage
  ]
  ////////////////////////////////////////////Simulator requirements////////////////////////////////////////////
	requirement SimulationToolCompatibilitySim1: "REQ-VDM-SIM-01 The model shall work on SimTool1 v_2304." [
	  description "The model shall be executable within the SimTool1 v_2304 simulation environment without functional degradation."
	  rationale "Ensuring compatibility with XTool is necessary for integration into the target simulation workflow."
	  category Simulation.SimulatorCompatibility
	  val ExpectedSimulator = 1 
	  value predicate #Simulator_Property::SimulatorName == ExpectedSimulator
	]
	
	requirement SimulationToolCompatibilityVersionSim2: "REQ-VDM-SIM-02 The model shall work on SimTool1 v_2304." [
	  description "The model shall be executable within the SimTool1 v_2304 simulation environment without functional degradation."
	  rationale "Ensuring compatibility with XTool is necessary for integration into the target simulation workflow."
	  category Simulation.SimulatorCompatibility
	  val ExpectedSimulatorVersion = 2304
	  value predicate #Simulator_Property::SimulatorVersion == ExpectedSimulatorVersion
	]
	
	requirement PlatformInterfaceCompatibilityScanerSim3: "REQ-VDM-SIM-03 The model shall be compatible with SimTool2 interfaces." [
	  description "The model shall correctly implement and exchange data through all required SimTool2 interface definitions."
	  rationale "Interface compatibility ensures correct communication and integration with the simulation platform."
	  category Simulation.SimulatorCompatibility
	  val CompatibilitySimTool = 1 //true
	  value predicate #Simulator_Property::CompatibilitySimTool2 == CompatibilitySimTool 
	]
	
	
	requirement NonRealTimeOperationSim4: "REQ-VDM-SIM-04 The model shall operate in non-real-time mode NRT." [
	  description "The model shall be able to execute without realtime constraints, allowing offline or accelerated simulations."
	  rationale "Non-real-time execution is essential for development, debugging, and large-scale scenario testing."
	  category Simulation.SimulatorCompatibility 
	  val NRT = 1 //true
	  value predicate #Simulator_Property::NRT == NRT 
	]
	
	requirement ModelInstantiabilitySim5: "REQ-VDM-SIM-05 The model shall be instantiable." [
	  description "The model shall support instantiation as a reusable component within the simulation environment."
	  rationale "Instantiability enables modularity, reuse, and integration into larger simulation architectures."
	  category Simulation.SimulatorCompatibility
	  val Instanciable = 1 //true
	  value predicate #Simulator_Property::Instantiable == Instanciable
	]
	
	requirement RelativePathsSim6: "REQ-VDM-SIM-06 The model shall use relative paths." [
	  description "All file references used by the model shall rely on relative paths rather than absolute paths."
	  rationale "Relative paths ensure portability and avoid environment-dependent configuration issues."
	  category Simulation.SimulatorCompatibility
	  val Paths = 1 //true
	  value predicate #Simulator_Property::PathsTypes == Paths
	]
	
	requirement WindowsCompatibilitySim7: "REQ-VDM-SIM-07 The model shall be compatible with Windows." [
	  description "The model shall execute correctly on Windows operating systems, including all required dependencies."
	  rationale "Windows compatibility is necessary for deployment on the target development and simulation machines."
	  category Simulation.SimulatorCompatibility 
	  val OS = 1 //true
	  value predicate #Simulator_Property::OSAdapted == OS
	]
	   
	  
	  



	
]