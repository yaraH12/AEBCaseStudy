			--outputs
			out001: out feature Custom_Types::CustomNm;
			out002: out feature Custom_Types::CustomNm;
			out003: out feature Custom_Types::CustomNm;
			out004: out feature Custom_Types::CustomNm;
			out005: out feature Custom_Types::CustomNm;
			out006: out feature Custom_Types::CustomPercentage;
			out007: out feature Custom_Types::CustomPercentage;
			out008: out feature Custom_Types::CustomNm;
			out009: out feature Custom_Types::CustomBoolean;
