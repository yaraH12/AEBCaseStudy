			out022: out feature Custom_Types::CustomNm;
			out023: out feature Custom_Types::CustomBoolean;
			out024: out feature Custom_Types::CustomNm;
			out025: out feature Custom_Types::CustomRADperS;
			out026: out feature Custom_Types::CustomRADperS;
			out027: out feature Custom_Types::CustomRADperS;
			out028: out feature Custom_Types::CustomRADperS;
			out029: out feature Custom_Types::CustomBar;
			out030: out feature Custom_Types::CustomBar;
			out031: out feature Custom_Types::CustomBar;
			out032: out feature Custom_Types::CustomBar;
			out033: out feature Custom_Types::CustomBar;
			out034: out feature Custom_Types::CustomBoolean;
