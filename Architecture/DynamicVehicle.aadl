			in011: in feature Custom_Types::CustomBoolean0;
			in012: in feature Custom_Types::CustomNm0;
			in013: in feature Custom_Types::CustomBoolean0;
			in014: in feature Custom_Types::CustomBoolean0;
			in015: in feature Custom_Types::CustomNm0;
