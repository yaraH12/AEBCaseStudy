			Validation_Property::ReachSpeedValid => 1;
			Validation_Property::ReachSpeedTurnLeftValid => 1;
			Validation_Property::ReachSpeedTurnRightValid => 1;
			Validation_Property::AccelerationValid => 1;
			Validation_Property::ModerateBreakingValid => 1;
			Validation_Property::FullBreakingValid => 1;
			Validation_Property::PrefillValid => 1;
			Validation_Property::CustomInputValid => 1;
			Verification_Property::TechnicalChecKCovered => 1;
	end VehicleDynamicStandalone.Impl;

	---------------------------------------------------------------------------------------
	-- DV variant 1 : No ADAS 
	---------------------------------------------------------------------------------------
	
	abstract VehicleDynamicv1 extends VehicleDynamicStandalone
		properties
			Verification_Property::Standalone => 1;
			Verification_Property::ADAS => 0;
			Verification_Property::VehicleType => 1;
			Verification_Property::EngineType => 2 ;
			Verification_Property::TT100Correlated => 1 ;
			Verification_Property::TTLCorrelated => 1;
			Verification_Property::Frequency => 100;
			Verification_Property::TiresBrand => 1;
			Verification_Property::TiresModel => 1;
			Verification_Property::TiresDimensions_width => 195;
			Verification_Property::TiresDimensions_aspectratio => 60 ;
			Verification_Property::TiresDimensions_rimdiameter => 16 ;
			Verification_Property::TiresPressure => 2.5 ;
			Validation_Property::ModerateBreakingValid => 0;
			Validation_Property::FullBreakingValid => 0;
			Verification_Property::TechnicalChecKCovered => 0;
			Verification_Property::VehicleTotalMass => 1715 ;
			Verification_Property::FrontMassDistribution => 51 ;
			Verification_Property::RearMassDistribution => 49 ;
			Simulator_Property::CompatibilitySimTool2 => 0 ;
			Simulator_Property::Instantiable => 0;
			
	end VehicleDynamicv1;
	
	abstract implementation VehicleDynamicv1.Impl
		subcomponents
			function01: abstract DVFeatures::Function01; 
			function02: abstract DVFeatures::Function02;
			function03 : abstract DVFeatures::Function03;
			function04: abstract DVFeatures::Function04;
			function05 : abstract DVFeatures::Function05;
			function06 : abstract DVFeatures::Function06;
			function07 : abstract DVFeatures::Function07;
			function08 : abstract DVFeatures::Function08;
			function10: abstract DVFeatures::Function10;
			function11 : abstract DVFeatures::Function11;
			function12 : abstract DVFeatures::Function12;
			function14 : abstract DVFeatures::Function13;
			function15: abstract DVFeatures::Function14;			
		properties
			Validation_Property::ToleranceMargin => 1;
			Validation_Property::ReachSpeedValid => 1;
			Validation_Property::AccelerationValid => 1;
			Validation_Property::ModerateBreakingValid => 0;
			Validation_Property::FullBreakingValid => 0;
			Validation_Property::ReachSpeedTurnLeftValid => 0;
			Validation_Property::ReachSpeedTurnRightValid => 0;
			Validation_Property::PrefillValid => 1;
			Validation_Property::CustomInputValid => 1;
			Verification_Property::TechnicalChecKCovered => 1;
			
			
	end VehicleDynamicv1.Impl;
	
