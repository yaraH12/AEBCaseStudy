			function10: abstract DVFeatures::Function10;
			function11 : abstract DVFeatures::Function11;
			function12 : abstract DVFeatures::Function12;
			function14 : abstract DVFeatures::Function13;
			function15: abstract DVFeatures::Function14;
				
		properties
