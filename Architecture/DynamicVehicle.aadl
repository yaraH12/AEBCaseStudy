	with Custom_Types;
	with Validation_Property;
	with Verification_Property;
	with Maturity_Property;
	with Simulator_Property;
	with DVFeatures;
	
	abstract VehicleDynamicStandalone
		features
			--inputs
			in001: in feature Custom_Types::CustomBoolean0 ;
			in002: in feature Custom_Types::CustomNm0;
			in003: in feature Custom_Types::CustomBoolean0;
			in004: in feature Custom_Types::CustomNm0;
			in005: in feature Custom_Types::CustomBoolean0;
